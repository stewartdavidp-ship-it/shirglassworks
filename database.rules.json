{
  "rules": {
    // ========== USER DATA ==========
    // Users can only read/write their own data
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        "shelf": {
          "wallet": {
            "tokens": {
              // Tokens: 0 to 50,000 range
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50000"
            },
            "coins": {
              // Coins: allow negative (debt from chargebacks) up to 10,000
              ".validate": "newData.isNumber() && newData.val() >= -1000 && newData.val() <= 10000"
            }
          },
          
          "games": {
            "$gameIndex": {
              ".validate": "newData.hasChildren(['id', 'name'])"
            }
          },
          
          "history": {
            "$date": {
              "$gameId": {
                ".validate": "newData.isString() || newData.hasChildren()"
              }
            }
          }
        },
        
        "displayName": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50"
        },
        
        "photoURL": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        
        "friendCode": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 20"
        },
        
        // Referral info - can only be set once
        "referral": {
          "referredBy": {
            ".write": "!data.exists()",
            ".validate": "newData.isString()"
          }
        },
        
        // Token transaction history
        "tokenHistory": {
          "$transactionId": {
            ".validate": "newData.hasChildren(['type', 'amount', 'timestamp'])"
          }
        },
        
        // Pending rewards from referrals
        "pendingReferralRewards": {
          "$rewardId": {
            ".validate": "newData.hasChildren(['type', 'tokens', 'timestamp'])"
          }
        },
        
        // Purchase lock flag (set by server on chargeback)
        "purchaseLocked": {
          ".write": false
        },
        
        // Account creation timestamp
        "createdAt": {
          ".write": "!data.exists()",
          ".validate": "newData.isNumber()"
        },
        
        // Last visit for activity tracking
        "lastVisit": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    
    // ========== FRIENDS ==========
    // Users can only manage their own friends list
    "friends": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        "$friendUid": {
          ".validate": "newData.hasChildren(['odataId', 'addedAt']) && newData.child('odataId').val() === $friendUid"
        }
      }
    },
    
    // ========== REFERRAL CODES ==========
    // Public read, owner-only write, referees write-once
    "referralCodes": {
      "$code": {
        ".read": true,
        ".write": "!data.exists() || data.child('ownerId').val() === auth.uid",
        
        "ownerId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        
        "ownerName": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        
        "referees": {
          "$refereeUid": {
            // Referee entry can only be created once, by the referee themselves
            ".write": "!data.exists() && $refereeUid === auth.uid",
            ".validate": "newData.hasChildren(['joinedAt']) && newData.child('joinedAt').isNumber()"
          }
        },
        
        "stats": {
          // Stats can be updated by owner
          ".write": "root.child('referralCodes').child($code).child('ownerId').val() === auth.uid"
        }
      }
    },
    
    // ========== BATTLES ==========
    "battles": {
      "$battleId": {
        // Participants and public battles can be read
        ".read": "data.child('participants').child(auth.uid).exists() || data.child('isPublic').val() === true",
        
        // Creator can create battle
        ".write": "!data.exists() && auth != null",
        
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
        },
        
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'active' || newData.val() === 'completed')"
        },
        
        "participants": {
          "$participantUid": {
            // Users can only update their own participant entry
            // Can join if battle not completed
            ".write": "$participantUid === auth.uid && (data.exists() || root.child('battles').child($battleId).child('status').val() !== 'completed')",
            
            "displayName": {
              ".validate": "newData.isString() && newData.val().length <= 50"
            },
            
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
            },
            
            "games": {
              "$gameId": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              }
            }
          }
        },
        
        "entryFee": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50"
        },
        
        "prizePool": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        
        "games": {
          ".validate": "newData.isString() || newData.hasChildren()"
        },
        
        "endDate": {
          ".validate": "newData.isNumber()"
        },
        
        "creatorId": {
          ".write": "!data.exists()",
          ".validate": "newData.val() === auth.uid"
        },
        
        "joinCode": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 10"
        },
        
        "isPublic": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    
    // ========== PUBLIC BATTLES LOBBY ==========
    "public-battles": {
      ".read": "auth != null",
      
      "$battleId": {
        ".write": "auth != null && (!data.exists() || data.child('creatorId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['name', 'endDate', 'creatorId'])"
      }
    },
    
    // ========== HINT USAGE (Rate Limiting) ==========
    "hint-usage": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        "requests": {
          ".validate": "newData.hasChildren()"
        }
      }
    },
    
    // ========== FAQ ANALYTICS ==========
    // Users can write their own FAQ usage data for improvement insights
    "faq-analytics": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        "views": {
          "$viewId": {
            ".validate": "newData.hasChildren(['faqId', 'timestamp'])"
          }
        },
        
        "searches": {
          "$searchId": {
            ".validate": "newData.hasChildren(['query', 'resultCount', 'timestamp']) && newData.child('query').val().length <= 100"
          }
        },
        
        "askAI": {
          "$clickId": {
            ".validate": "newData.hasChildren(['timestamp'])"
          }
        }
      }
    },
    
    // ========== PUBLIC PROFILES (Friends Today) ==========
    // Authenticated users can read any public profile
    // Users can only write their own public profile
    "gameshelf-public": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        
        "photoURL": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        
        "inviteCode": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        
        "gamesTracked": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        },
        
        "currentStreak": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000"
        },
        
        "todayCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        },
        
        "lastUpdated": {
          ".validate": "newData.isNumber()"
        },
        
        "lastActivity": {
          ".validate": "newData.hasChildren(['gameId', 'date'])"
        }
      }
    },
    
    // ========== SERVER-ONLY PATHS ==========
    // These are written by Cloud Functions which bypass security rules
    
    "purchases": {
      ".read": false,
      ".write": false,
      "$uid": {
        ".indexOn": ["stripeSessionId", "timestamp"]
      }
    },
    
    "flaggedAccounts": {
      ".read": false,
      ".write": false
    },
    
    "giftRedemptions": {
      ".read": false,
      ".write": false
    },
    
    "hint-analytics": {
      ".read": false,
      ".write": false
    },
    
    "securityAudit": {
      ".read": false,
      ".write": false
    },
    
    // ========== COMMAND CENTER ==========
    // Client-side: read-only access to own data (browser dashboard).
    // Writes go through MCP server (Firebase Admin SDK, bypasses rules).
    // Indexes required for server-side queries.
    "command-center": {
      ".write": false,

      "system": {
        "oauth": {
          "tokenIndex": {
            ".indexOn": ["expiresAt"]
          },
          "clients": {
            ".indexOn": ["created_at"]
          },
          "auditLog": {
            ".indexOn": ["timestamp"]
          }
        }
      },

      "public": {
        "stats": {
          ".read": true,
          ".write": false
        },
        "stories": {
          ".read": false,
          "$storyId": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['name', 'story', 'createdAt']) && newData.child('name').isString() && newData.child('story').isString() && newData.child('story').val().length <= 2000"
          }
        },
        "session-stories": {
          ".read": true,
          ".write": false
        }
      },

      "$uid": {
        ".read": "$uid === auth.uid",

        "oauth": {
          "tokens": {
            ".indexOn": ["expiresAt"]
          }
        },
        "documents": {
          ".indexOn": ["status"]
        },
        "sessions": {
          ".indexOn": ["status"]
        },
        "jobs": {
          ".indexOn": ["status"]
        },
        "concepts": {
          ".indexOn": ["status", "type", "ideaOrigin"]
        }
      }
    },

    // ========== SHIR GLASSWORKS ==========
    // Public site reads from shirglassworks/public (no auth).
    // Admin writes require Google Sign-In with whitelisted UID.
    "shirglassworks": {
      ".write": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1'",

      "public": {
        ".read": true,

        "events": {
          ".indexOn": ["date", "visible"],
          "$eventId": {
            ".validate": "newData.hasChildren(['date', 'name', 'location', 'visible'])"
          }
        },
        "gallery": {
          ".indexOn": ["order", "visible", "category"],
          "$imageId": {
            ".validate": "newData.hasChildren(['url', 'alt', 'order', 'visible'])"
          }
        },
        "products": {
          "$productId": {
            ".validate": "newData.hasChildren(['pid', 'name', 'url', 'categories'])"
          }
        }
      },

      // Customer accounts — each authenticated user can read/write their own record
      "customers": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      },

      "admin": {
        // Read: admin always, or any user with a non-guest RBAC role
        ".read": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1' || (auth != null && root.child('shirglassworks/admin/users').child(auth.uid).child('role').exists() && root.child('shirglassworks/admin/users').child(auth.uid).child('role').val() !== 'guest')",
        // Write: admin always, or any user with a non-guest RBAC role
        ".write": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1' || (auth != null && root.child('shirglassworks/admin/users').child(auth.uid).child('role').exists() && root.child('shirglassworks/admin/users').child(auth.uid).child('role').val() !== 'guest')",

        // Invites — any authenticated user can read (first-login lookup), admin-only write
        "invites": {
          ".read": "auth != null",
          ".write": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1' || (auth != null && root.child('shirglassworks/admin/users').child(auth.uid).child('role').val() === 'admin')"
        },

        // RBAC roles — any authenticated user can read (to cache their permission config)
        "roles": {
          ".read": "auth != null"
        },

        // RBAC user records — users can read their own record and create it on first sign-in
        // (guest auto-provisioning). Cannot update own record (role elevation blocked).
        // Admin can read/write all (inherited from parent rules).
        "users": {
          "$uid": {
            ".read": "auth.uid === $uid",
            ".write": "auth.uid === $uid && !data.exists()"
          }
        },

        "sales": {
          ".indexOn": ["timestamp", "status", "paymentType", "eventId"]
        },
        "salesEvents": {
          ".indexOn": ["date", "status"]
        },
        "locations": {
          ".indexOn": ["status", "type", "createdAt"]
        },
        "square-payments": {
          ".indexOn": ["createdAt", "matchedSaleId", "status"]
        },
        "contacts": {
          "$contactId": {
            "interactions": {
              ".indexOn": ["date"]
            }
          }
        },

        // Commissions — anonymous push-only writes from public website, admin reads inherited
        "commissions": {
          ".indexOn": ["status", "createdAt"],
          "$commissionId": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['customerName', 'customerContact', 'status', 'channel', 'createdAt']) && newData.child('customerName').isString() && newData.child('customerName').val().length >= 1 && newData.child('customerName').val().length <= 200 && newData.child('customerContact').isString() && newData.child('customerContact').val().length >= 1 && newData.child('customerContact').val().length <= 200 && (newData.child('status').val() === 'new') && (newData.child('channel').val() === 'web' || newData.child('channel').val() === 'pos') && newData.child('createdAt').isString()"
          }
        },

        // Audit trail — global chronological log (Phase E2)
        // Append-only: any authenticated user can create entries, nobody can update/delete
        // Admin-only reads (inherited from parent .read)
        "auditLog": {
          ".indexOn": ["time", "event/entity"],
          "$entryId": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.hasChildren(['event', 'actor', 'time'])"
          }
        },

        // Audit trail — per-entity index for record-level history
        "auditIndex": {
          "$entity": {
            "$entityId": {
              "$entryId": {
                ".write": "auth != null && !data.exists()",
                ".validate": "newData.hasChildren(['event', 'actor', 'time'])"
              }
            }
          }
        }
      },

      // Image library: public read (shop/gallery display), admin write (via top-level .write)
      "images": {
        ".read": true
      },

      // Analytics: anonymous push-only writes, admin-only reads
      "analytics": {
        "hits": {
          ".read": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1'",
          ".indexOn": ["ts", "d"],
          "$hitId": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['t','p','ts','d']) && (newData.child('t').val() === 'pv' || newData.child('t').val() === 'ev') && newData.child('ts').isNumber() && newData.child('ts').val() > 1700000000000 && newData.child('ts').val() < 2000000000000 && newData.child('p').isString() && newData.child('p').val().length <= 20 && newData.child('d').isString() && newData.child('d').val().length === 10 && (!newData.hasChild('a') || (newData.child('a').isString() && newData.child('a').val().length <= 40)) && (!newData.hasChild('ip') || (newData.child('ip').isString() && newData.child('ip').val().length <= 45))"
          }
        }
      },

      // User carts: each authenticated user can read/write their own cart
      "users": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid",
          "cart": {
            "$itemId": {
              ".validate": "newData.hasChildren(['pid','name','qty']) && newData.child('pid').isString() && newData.child('qty').isNumber() && newData.child('qty').val() >= 1 && newData.child('qty').val() <= 10"
            }
          }
        }
      },

      // Orders: written by Cloud Functions (submit) + admin (status updates)
      // Individual order status is publicly readable (orderId acts as auth token)
      // for the confirmation page Firebase listener
      "orders": {
        ".read": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1'",
        ".write": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1'",
        ".indexOn": ["squareOrderId", "etsyReceiptId", "source", "uid", "orderNumber"],
        "$orderId": {
          "status": {
            ".read": true
          }
        }
      },

      // Private config: admin-only metadata (environment, locationId, shopId, etc.)
      // Secrets (accessToken, webhookSignatureKey, apiKey, refreshToken) have been migrated
      // to GCP Secret Manager and removed from RTDB. Admin UI uses shirSecretsManager callable.
      "config": {
        ".read": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1'",
        ".write": "auth.uid === 'oUt4ba0dYVRBfPREqoJ1yIsJKjr1'"
      }
    },

    // ========== DEFAULT DENY ==========
    // Deny all other paths
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
